# ── PostgreSQL bağlantısı ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Windows-da default PostgreSQL quraşdırma:
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/naxchivan_erp

# ── JWT məxfi açar ────────────────────────────────────────────────
# İstənilən uzun, təsadüfi mətn (minimum 32 simvol). Heç kimə vermə.
JWT_SECRET=buraya_uzun_bir_sirli_metn_yaz_minimum_32_simvol_olsun

# ── API serverin portu ───────────────────────────────────────────
PORT=8080
